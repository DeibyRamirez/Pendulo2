# ── Broker MQTT (Mosquitto corriendo LOCAL en la Raspberry Pi) ──────────────
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=pendulo_uac
MQTT_PASSWORD=pendulo_uac
# Topico de escucha (telemetria que publica Node-RED / la Pi). Confirmado
# con mosquitto_sub real: los datos llegan planos en "pendulo/mediciones".
# IMPORTANTE: van entre comillas porque el "#" sin comillas se interpreta
# como inicio de comentario en el parser de .env (y trunca el valor).
MQTT_SUB_TOPIC="pendulo/#"
# Topico donde este bridge publica los comandos (web -> pendulo) para que
# Node-RED los traduzca a serial (cfg/str). Un solo pendulo por bridge, asi
# que es un topico fijo (sin id de pendulo en el medio).
MQTT_CMD_TOPIC=pendulo/comando

# ── Firebase Admin SDK ───────────────────────────────────────────────────────
# Ruta al JSON de la cuenta de servicio (NUNCA subir este archivo a git).
# Colocalo en la Raspberry Pi, fuera de cualquier carpeta versionada.
GOOGLE_APPLICATION_CREDENTIALS=/home/pi/secrets/pendulo-firebase-adminsdk.json
FIREBASE_PROJECT_ID=pendulo-cd66e

# ── Identificacion del pendulo que atiende este bridge ──────────────────────
# Si en el futuro hay varios pendulos por instancia de bridge, esto pasa a ser
# el default cuando el topico MQTT no trae el id explicito.
DEFAULT_PENDULO_ID=UAC-01

# ── Throttling de escritura a Firestore (ms) ────────────────────────────────
# Minimo tiempo entre escrituras del historico (subcoleccion "lecturas") por
# pendulo, para no disparar el costo/cuota de Firestore con mensajes muy
# frecuentes. El documento "en vivo" siempre se actualiza en cada mensaje.
LECTURAS_THROTTLE_MS=300

# Nivel de log: debug | info | warn | error
LOG_LEVEL=info
